    {
      "hotkey": "Alt+Shift+Left",
      "action": "monitor",
      "monitor": "previous",
      "placement": "preserve-relative"
    },
    {
      "hotkey": "Ctrl+Alt+1",
      "target": "left-main"
    },
    {
      "hotkey": "Ctrl+Alt+2",
      "target": "center-main"
    },
    {
      "hotkey": "Ctrl+Alt+3",
